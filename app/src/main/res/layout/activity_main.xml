<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_screen">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestor de Tareas"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sesión iniciada"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnAddTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Agregar nueva tarea"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnOpenMap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver mi ubicación"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/secondary"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar sesión"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/danger"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tareas guardadas"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Toca una tarea para editarla o eliminarla"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay tareas guardadas. Agrega una nueva tarea para comenzar."
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="18dp"
        android:background="@drawable/bg_card"
        android:visibility="gone"
        android:layout_marginBottom="10dp" />

    <ListView
        android:id="@+id/listTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="10dp"
        android:background="@android:color/transparent" />

</LinearLayout>